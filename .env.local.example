# DeutschFit web — local environment template.
#
# Copy this file to `.env.local` and fill in real values. Do NOT commit
# `.env.local`. The CI workflow (.github/workflows/ci.yml) injects
# placeholders for the NEXT_PUBLIC_* vars so the build can run without
# secrets — runtime wiring (Supabase, Resend, payment toggles) lives here.
#
# Variables prefixed with NEXT_PUBLIC_ are inlined at build time and exposed
# to the browser. Anything sensitive must NOT use that prefix.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL + publishable (anon) key. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Service-role key. Bypasses RLS — server-only, never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (transactional email) ────────────────────────────────────────────
# RESEND_API_KEY is server-only. The activation-email helper throws
# EmailNotConfiguredError if it's unset (so W4 surfaces it cleanly).
RESEND_API_KEY=re_your_api_key

# ─── Site ────────────────────────────────────────────────────────────────────
# Public origin used for absolute URLs (magic-link callbacks, OG images, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Operator payment handles (public; rendered on /how-to-pay) ──────────────
# These show up on the public /how-to-pay page so a learner can pay
# out-of-band before the operator activates their plan. NEXT_PUBLIC_*
# because the page is statically rendered (with revalidation) and the
# values aren't secrets — they're public phone numbers / handles. Leave
# any unset and the channel renders a "Coming soon" placeholder.
NEXT_PUBLIC_PAY_MOMO_NUMBER=
NEXT_PUBLIC_PAY_OM_NUMBER=
NEXT_PUBLIC_PAY_BANK_DETAILS=
NEXT_PUBLIC_PAY_PAYPAL_HANDLE=
NEXT_PUBLIC_PAY_WISE_HANDLE=
NEXT_PUBLIC_PAY_EMAIL=support@deutschfit.app
