# DeutschFit web — local environment template.
#
# Copy this file to `.env.local` and fill in real values. Do NOT commit
# `.env.local`. The CI workflow (.github/workflows/ci.yml) injects
# placeholders for the NEXT_PUBLIC_* vars so the build can run without
# secrets — runtime wiring (Supabase, Resend, payment toggles) lives here.
#
# Variables prefixed with NEXT_PUBLIC_ are inlined at build time and exposed
# to the browser. Anything sensitive must NOT use that prefix.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL + publishable (anon) key. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Service-role key. Bypasses RLS — server-only, never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM=DeutschFit <noreply@your-domain.com>

# ─── Site ────────────────────────────────────────────────────────────────────
# Public origin used for absolute URLs (magic-link callbacks, OG images, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Operator payment handles (server-only) ──────────────────────────────────
# These appear on /how-to-pay once W3 wires the page. They MUST NOT be
# NEXT_PUBLIC_* — leaking the operator's MoMo/OM number on the wire is fine,
# but coupling them to a build artefact makes rotation painful.
OPERATOR_MOMO_NUMBER=
OPERATOR_OM_NUMBER=
OPERATOR_BANK_DETAILS=
OPERATOR_PAYPAL_EMAIL=
OPERATOR_WISE_HANDLE=

# ─── Payment-method toggles (public) ─────────────────────────────────────────
# Per-method on/off switches read at build time so /pricing and /how-to-pay
# can hide a payment method when the operator pauses it. Keep "true" / "false"
# string values — coercion happens in the loader.
NEXT_PUBLIC_PAYMENT_MOMO_ENABLED=true
NEXT_PUBLIC_PAYMENT_OM_ENABLED=true
NEXT_PUBLIC_PAYMENT_BANK_ENABLED=true
NEXT_PUBLIC_PAYMENT_PAYPAL_ENABLED=false
NEXT_PUBLIC_PAYMENT_WISE_ENABLED=false
