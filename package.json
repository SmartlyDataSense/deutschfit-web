{
  "name": "deutschfit-web",
  "version": "0.1.0",
  "private": true,
  "description": "DeutschFit public web + back-office (Next.js)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md,css}\" \"*.{ts,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md,css}\" \"*.{ts,mjs,json,md}\"",
    "test": "vitest",
    "test:run": "vitest --run",
    "e2e": "playwright test",
    "types:sync": "node scripts/sync-types.mjs",
    "preflight": "npm run typecheck && npm run lint && npm run format:check && npm run test:run && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "clsx": "^2.1.1",
    "next": "15.5.15",
    "next-intl": "^4.9.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
